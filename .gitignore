# Config locale (chemin ROM perso) + presets générés (régénérés par l'app)
# (en dev/portable, ces données vont dans /randomizer, /data, /saves, /roms à la racine)
/randomizer/
app/randomizer/config.json
app/randomizer/soulsync-preset.rnqs
app/randomizer/soulsync-preset.properties

# Réglages Claude locaux (permissions machine)
.claude/settings.local.json

# Données runtime (échange Lua <-> app)
data/*
!data/.gitkeep

# Sauvegardes de parties (locales à chaque machine)
saves/

